generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Logo {
  id          String  @id @default(uuid())
  favoritedBy User[]  @relation("UserFavorites")
  // ── Core identity ──────────────────────────────────────────────────────────
  logoName    String
  slug        String  @unique
  brand       String?
  website     String?

  // ── Classification ─────────────────────────────────────────────────────────
  category String
  industry String?
  country  String?
  license  String?

  // ── Content ────────────────────────────────────────────────────────────────
  description String
  history     String?

  // ── Taxonomy ───────────────────────────────────────────────────────────────
  tags        Json @default("[]")
  brandColors Json @default("[]")

  // ── File URLs ──────────────────────────────────────────────────────────────
  // Public (CDN-accessible)
  webpUrl String? // public/{slug}/*.webp  ← only public file

  // Private (gated / signed-URL download)
  svgUrl String? // separate/{slug}/*.svg
  pngUrl String? // separate/{slug}/*.png
  aiUrl  String? // separate/{slug}/*.ai
  cdrUrl String? // separate/{slug}/*.cdr

  svgfilesize String? @default("0 kb")
  pngfilesize String? @default("0 kb")
  aifilesize  String? @default("0 kb")
  cdrfilesize String? @default("0 kb")

  // ── SVG source code ────────────────────────────────────────────────────────
  // Raw <svg>…</svg> markup extracted from the ZIP.
  // Stored as Text so it can be served inline or used for server-side rendering.
  svgContent String? @db.Text

  // ── SEO ────────────────────────────────────────────────────────────────────
  metaTitle       String?
  metaDescription String?
  altText         String?
  focusKeywords   String?

  // ── Publishing ─────────────────────────────────────────────────────────────
  publishStatus String @default("Draft")

  // "unlimited" or a numeric string e.g. "5", "100"
  downloadCount            String @default("unlimited")
  downloadedNumberByPeople Int    @default(0)

  // ── Timestamps ─────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Indexes ────────────────────────────────────────────────────────────────
  @@index([slug])
  @@index([category])
  @@index([publishStatus])
}

model Website {
  id         String   @id @default(uuid())
  categories Json?
  navItems   Json?
  watermark  Json?
  Footer     Json?
  metaTitle       String?
  metaDescription String?
  limit           Int @default(20)
  MaintanceMessage String?
  showmode    Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id String @id @default(uuid())

  // ── Basic Info ─────────────────────────────
  name     String?
  email    String? @unique
  password String?

  // role
  role String @default("user") // "user" or "admin"

  // ── Auth Type ─────────────────────────────
  // guest OR logged
  type String @default("guest")

  // ── Download Tracking ─────────────────────
  downloadCountUsed Int @default(0)
  downloadLimit     Int @default(5) // guest = 5, logged = unlimited (or high)

  // ── Favorites Relation ────────────────────
  favorites Logo[] @relation("UserFavorites")

  // ── Optional: Email Verification ──────────
  isVerified        Boolean @default(false)
  verificationToken String?

  // ── Timestamps ────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id            String   @id @default(uuid())
  title         String
   mode          String   @default("editor") 
  slug          String   @unique
  content       String?  // HTML from Tiptap
  publishStatus String   @default("draft") // "published" | "draft"
  InFooter       Boolean @default(false)
  InLegal        Boolean @default(false)
  InHome         Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())

  // who performed the action (userId, system, api, etc.)
  who       String

  // log message / description
  content   String   @db.Text

  // timestamp
  createdAt DateTime @default(now())
}

enum ContactStatus {
  pending
  replied
}

model LogoRequest {
  id             String   @id @default(uuid())

  // ── Submitted by user ────────────────────────────────────────────────────
  brandName      String
  websiteUrl     String?
  category       String?

  // Preferred file formats e.g. ["AI","SVG","PNG"]
  formats        Json     @default("[]")

  notes          String?  
  requesterEmail String?

  // ── Admin workflow ────────────────────────────────────────────────────────
  // "pending" | "in_progress" | "completed" | "rejected"
   status     ContactStatus @default(pending)
  adminNotes     String? 

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([brandName])
}


model ContactMessage {
  id      String  @id @default(uuid())

  // ── From visitor ─────────────────────────────────────────────────────────
  name    String
  email   String
  subject String?
  message String  

  // ── Admin workflow ────────────────────────────────────────────────────────
  // "unread" | "read" | "replied" | "archived"
   status     ContactStatus @default(pending)
  adminReply  String? 

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
}



model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  category    String
  coverEmoji  String   @default("📝")
  readTime    Int      @default(5)   // in minutes
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
